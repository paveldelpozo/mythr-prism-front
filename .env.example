# URL publica (HTTPS) que se codifica en el QR de pairing remoto.
# Ejemplo: https://mythr-prism-demo.trycloudflare.com
# Si se deja vacia, el QR usa window.location.origin.
VITE_REMOTE_PUBLIC_URL=

# URL del backend remoto (Socket.IO) para pairing/control remoto.
# En desarrollo local, si se deja vacia, el front usa http://localhost:3000.
VITE_REMOTE_BACKEND_URL=
