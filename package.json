{
  "name": "mythr-prism",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.12.0",
    "pnpm": ">=8.15.9"
  },
  "packageManager": "pnpm@8.15.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
